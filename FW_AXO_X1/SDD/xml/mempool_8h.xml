    <innerclass refid="class_memory_pool" prot="public">MemoryPool</innerclass>
    <briefdescription>
<para>Header file of RTOS wrapper class mempool for message allocation support. </para>
    </briefdescription>
    <detaileddescription>
<para><simplesect kind="par"><title>Project </title><para>AXO Track Firmware 2023</para>
</simplesect>
<simplesect kind="copyright"><para>(c) 2023 AXO Track GmbH, Berlin. All rights reserved.</para>
